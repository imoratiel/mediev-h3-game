meta {
  name: auth/login
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/auth/login
  body: json
  auth: inherit
}

body:json {
  {
    "username":"{{username}}",
    "password":"{{password}}"
  }
}

script:post-response {
  // Si tu API devuelve { "token": "ey..." }
  const data = res.getBody();
  
  if (data.token) {
    bru.setEnvVar("jwt_token", data.token);
    console.log("Token actualizado correctamente");
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
