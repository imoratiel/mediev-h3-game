# Database
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_HOST=db
DB_PORT=5432
DB_NAME=marca_hispanica
DATABASE_URL=postgresql://postgres:your_db_password_here@db:5432/marca_hispanica

# Server
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=your_jwt_secret_here

# ── AI Proxy (AIProxyService) ──────────────────────────────────────────────
# Provider is controlled via the Admin Panel UI (stored in global_settings DB table).
# Set API keys here if you want to use external AI providers.

# Google Gemini 1.5 Flash (recommended — lowest cost)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI GPT-4o Mini (alternative)
OPENAI_API_KEY=your_openai_api_key_here
