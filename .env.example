# ── Base de datos ─────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=cambia_esto_por_una_password_segura
DB_HOST=db
DB_PORT=5432
DB_NAME=marca_hispanica
DATABASE_URL=postgresql://postgres:cambia_esto@db:5432/marca_hispanica

# ── Seguridad ─────────────────────────────────────────────────
# Genera uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_cadena_larga_y_aleatoria

# ── Servidor ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── CORS: URL pública del cliente ─────────────────────────────
# En Hetzner: http://TU_IP:8080  o  https://tudominio.com
CORS_ORIGINS=http://TU_IP:8080

# ── APIs externas (opcionales) ────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Debug ───────────────────────────────────────────────────
DEBUG_COMBAT=false      # true → log detallado de cada combate en engine.log
